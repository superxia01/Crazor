{
  "productName": "Crazor",
  "version": "1.0.0",
  "identifier": "com.crazor.desktop",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Crazor 数字员工系统",
        "url": "http://localhost:3001",
        "width": 1440,
        "height": 900,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
