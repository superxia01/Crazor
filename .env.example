# Crazor Docker 部署配置

# 多个本地工作副本需要同时运行时，改成不同项目名。
COMPOSE_PROJECT_NAME=crazor
COMPOSE_PROFILES=hermes

# Web 统一入口端口，会暴露给宿主机和局域网。
CRAZOR_WEB_PORT=5173

# Crazor 后端允许的前端来源。Tauri 客户端必须保留 tauri://localhost / http://tauri.localhost。
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,tauri://localhost,http://tauri.localhost,https://tauri.localhost

# Agent Gateway 抽象层。默认 provider 是 Hermes，后续可切换到 Dify、自研 Agent Gateway 或其他兼容实现。
AGENT_PROVIDER=hermes
AGENT_GATEWAY_URL=http://hermes:8642
AGENT_DASHBOARD_URL=http://hermes:9119
AGENT_GATEWAY_API_KEY=change-me-run-scripts-hermes-init

# Hermes 是默认内置 provider；切换外部 provider 时可以关闭 COMPOSE_PROFILES 中的 hermes。
HERMES_IMAGE=nousresearch/hermes-agent:main
HERMES_GATEWAY_URL=http://hermes:8642
HERMES_DASHBOARD_URL=http://hermes:9119

# 兼容旧配置名，首次运行 ./scripts/hermes init 会与 AGENT_GATEWAY_API_KEY 同步。
HERMES_API_SERVER_KEY=change-me-run-scripts-hermes-init
API_SERVER_CORS_ORIGINS=http://localhost:9119,http://localhost:5173

# Hermes 直连端口默认只绑定本机；Crazor 通过 Compose 内网访问 Hermes。
HERMES_GATEWAY_BIND=127.0.0.1
HERMES_DASHBOARD_BIND=127.0.0.1
HERMES_WORKSPACE_ROOT=/opt/data/workspaces
HERMES_USER_WORKDIR=/opt/data/workspaces/users/default
HERMES_UID=1000
HERMES_GID=1000
HERMES_DASHBOARD=1
HERMES_DASHBOARD_HOST=0.0.0.0
HERMES_DASHBOARD_PORT=9119
HERMES_DASHBOARD_TUI=1
API_SERVER_ENABLED=true
API_SERVER_HOST=0.0.0.0
HERMES_SHM_SIZE=1gb
LOG_MAX_SIZE=20m
LOG_MAX_FILE=5

# 模型 provider 凭证。至少配置其中一个，否则 Hermes Gateway 只能启动，不能对话。
# 推荐 MVP 先用 OpenRouter：OPENROUTER_API_KEY + model.provider=openrouter。
OPENROUTER_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_BASE_URL=
NOUS_API_KEY=
GLM_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
HF_TOKEN=
NVIDIA_API_KEY=
XIAOMI_API_KEY=
ARCEEAI_API_KEY=
OLLAMA_API_KEY=
OLLAMA_BASE_URL=
LM_API_KEY=
LM_BASE_URL=
KILOCODE_API_KEY=
GITHUB_TOKEN=

# 时区。
TZ=Asia/Shanghai
CRON_TZ=Asia/Shanghai

# 首次启动保持正式空数据。只有明确需要演示数据时才设为 true。
CRAZOR_SEED_DEMO_DATA=false

# 客户登录配置。JWT_SECRET 留空时不强制登录；客户交付环境建议设置强密钥，
# 并同时配置 WECHAT_APP_ID / WECHAT_APP_SECRET 以启用微信扫码登录。
JWT_SECRET=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
DEPLOYMENT_TIER=free

# 客户交付身份。客户安装包启动时会用内置客户名核对后端声明，避免误连测试环境或其他客户环境。
CRAZOR_DELIVERY_CUSTOMER=
CRAZOR_DELIVERY_CHANNEL=customer
CRAZOR_PUBLIC_BASE_URL=
CRAZOR_CUSTOMER_SERVER_PREFLIGHT=warn

# 写入认证边界。设为 true 后，业务写入必须携带有效 API/Agent token。
# 首次部署若没有 active token，仍允许创建第一个身份和 token，避免初始化锁死。
CRAZOR_REQUIRE_WRITE_TOKEN=false

# 敏感只读边界。留空时跟随 CRAZOR_REQUIRE_WRITE_TOKEN；设为 true 后，
# audit logs、团队成员列表、token 列表必须携带有权限的 token。
CRAZOR_REQUIRE_SENSITIVE_READ_TOKEN=

# 只读总边界。设为 true 后，同时开启敏感只读和业务只读保护。
CRAZOR_REQUIRE_READ_TOKEN=

# 业务只读边界。默认关闭；设为 true 后，已有 active token 时，客户、项目、
# 任务、内容、文档、渠道、财务和分析等业务读取接口也必须携带有权限的 token。
CRAZOR_REQUIRE_BUSINESS_READ_TOKEN=false

# 客户附件归档策略。默认限制单个附件 20MB，预览仅读取 512KB 以内的文本/图片。
CRAZOR_ATTACHMENT_MAX_BYTES=20971520
CRAZOR_ATTACHMENT_PREVIEW_MAX_BYTES=524288
CRAZOR_ATTACHMENT_ALLOWED_EXTENSIONS=txt,md,csv,json,pdf,doc,docx,xls,xlsx,ppt,pptx,png,jpg,jpeg,webp,gif,zip,mp3,m4a,wav,mp4,mov
